# EcoVision AI - Environment Variables Template
# Copy this file to .env.local and fill in your Gemini API Key.

# 1. Google Gemini API Key from Google AI Studio (https://aistudio.google.com/)
# Make sure your project has Gemini API enabled in Google Cloud Console.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# 2. AI Provider Selection
# Options: 'gemini' (uses live Gemini model) or 'mock' (uses local mock simulation)
NEXT_PUBLIC_AI_PROVIDER=mock
